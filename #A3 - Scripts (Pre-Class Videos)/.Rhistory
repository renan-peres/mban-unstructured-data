install.packages("igraph")
library(igraph)
# install.packages("igraph")
library(igraph)
bigram_graph <- bigram_counts %>%
filter(n>20) %>%
graph_from_data_frame()
bigram_graph
install.packages("ggraph")
library(ggraph)
library(ggraph)
ggraph(bigram_graph, layout = "fr") +
geom_edge_link()+
geom_node_point()+
geom_node_text(aes(label=xxxxxxxxx), vjust =1, hjust=1)
library(ggraph)
ggraph(bigram_graph, layout = "fr") +
