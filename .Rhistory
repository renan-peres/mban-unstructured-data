flights %>%
select(today = year, everything()) %>%
select(1:4, 4:8) %>%
mutate(today = paste(today,month,day,sep = "-")) %>%
mutate(today = lubridate::as_date(today)) %>%
arrange(desc(today)) %>%
filter(today > '2013-06-01', month < 12) %>%
group_by(month) %>%
summarise(., number = n()) %>%
ggplot(aes(x = month,
y = number,
fill = number,
color = number)) +
#Tilte & Labels
ggtitle("Test") +
xlab("Distance") +
ylab("count")+
geom_col() +
scale_color_viridis_c(option = "magma") +
theme(plot.title = element_text(size =13),
legend.position = element_blank())
